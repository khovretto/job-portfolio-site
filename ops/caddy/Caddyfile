khovrov.dev {
  encode zstd gzip
  reverse_proxy app:3000
}

www.khovrov.dev {
  redir https://khovrov.dev{uri} permanent
}

stats.khovrov.dev {
  encode zstd gzip
  reverse_proxy umami:3000
}

chat.khovrov.dev {
  encode zstd gzip

  # Mnemosyne career-public broker — same-origin OpenAPI tool server for the
  # portfolio demo. Profile-pinned (career_public → mnm_public_real only) in the
  # mnemosyne-broker-api-public container; gated by its own bearer token.
  # /health is blocked at the proxy so it does not leak profile/collection names.
  handle_path /toolservers/mnemosyne-public/* {
    @health path /health
    respond @health 404
    reverse_proxy mnemosyne-broker-api-public:8765
  }

  handle {
    reverse_proxy openwebui:8080
  }
}

kb-audit.khovrov.dev {
  encode zstd gzip

  handle /admin* {
    basic_auth {
      admin {$CADDY_KB_AUDIT_ADMIN_HASH}
    }
    reverse_proxy kb-rag-auditor-app:3000
  }

  handle /api/admin* {
    basic_auth {
      admin {$CADDY_KB_AUDIT_ADMIN_HASH}
    }
    reverse_proxy kb-rag-auditor-app:3000
  }

  handle {
    reverse_proxy kb-rag-auditor-app:3000
  }
}

automation.khovrov.dev {
  encode zstd gzip

  handle /webhook* {
    reverse_proxy khovrov-n8n:5678
  }

  handle /webhook-test* {
    reverse_proxy khovrov-n8n:5678
  }

  handle {
    basic_auth {
      admin {$CADDY_AUTOMATION_ADMIN_HASH}
    }
    reverse_proxy khovrov-n8n:5678
  }
}
